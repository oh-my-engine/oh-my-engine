{
  "version": "1.0.0",
  "project": {
    "name": "Oh My Engine",
    "type": "workflow-engine",
    "framework": "node"
  },
  "workflows": {
    "ui-restore": {
      "enabled": true,
      "description": "从设计稿还原 UI 组件",
      "skills": ["ome-ui"],
      "rules": ["theme", "i18n", "design-tokens"],
      "options": {}
    },
    "bug-analysis": {
      "enabled": true,
      "description": "分析和修复 Bug",
      "skills": ["ome-bug"],
      "rules": ["code-style"],
      "options": {}
    },
    "component-gen": {
      "enabled": true,
      "description": "生成可复用组件",
      "skills": ["ome-comp"],
      "rules": ["theme", "i18n", "design-tokens"],
      "options": {}
    },
    "api-integration": {
      "enabled": true,
      "description": "集成 API 接口",
      "skills": ["ome-api"],
      "rules": ["code-style"],
      "options": {}
    },
    "spec": {
      "enabled": true,
      "description": "基于规范驱动的开发工作流",
      "skills": ["ome-spec"],
      "rules": ["code-style", "documentation", "testing"],
      "options": {
        "specRoot": ".ome/spec",
        "changesDir": ".ome/spec/changes",
        "specsDir": ".ome/spec/specs",
        "archiveDir": ".ome/spec/archive",
        "memoryDir": ".ome/memory/specs",
        "defaultFlow": "import-decompose-plan-apply-verify-archive",
        "manualFlow": "propose-plan-apply-verify-archive",
        "contextDirName": "context",
        "assetsDirName": "assets",
        "verifyCommands": ["npm test"]
      }
    }
  },
  "rules": {
    "theme": {
      "description": "主题系统规则",
      "required": true
    },
    "i18n": {
      "description": "多语言规则",
      "required": true
    },
    "design_tokens": {
      "description": "设计令牌规则",
      "required": true
    },
    "code_style": {
      "description": "代码风格规则",
      "required": true
    }
  },
  "memory": {
    "enabled": true,
    "captureMode": "selective",
    "allowSources": {
      "workflow_command": true,
      "explicit_remember": true,
      "post_run_promotion": true
    },
    "thresholds": {
      "preferencePromotion": 0.8,
      "knowledgePromotion": 0.85,
      "skillCandidatePromotion": 0.9
    },
    "retention_days": 90
  },
  "evolution": {
    "enabled": true,
    "autoApply": false,
    "requireVerification": true,
    "candidateOnly": true,
    "thresholds": {
      "learningCandidateMinEvidence": 3,
      "skillCandidateMinEvidence": 3,
      "adoptedPreferenceMinEvidence": 2
    }
  }
}
