{
  "name": "oh-my-engine",
  "version": "0.4.4",
  "description": "Cross-agent workflow engine for rules, memory, specs, and skills.",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "ome": "dist/bin/ome.js",
    "ome-init": "dist/bin/ome-init.js",
    "ome-bug": "dist/bin/ome-bug.js",
    "ome-ui": "dist/bin/ome-ui.js",
    "ome-comp": "dist/bin/ome-comp.js",
    "ome-api": "dist/bin/ome-api.js",
    "ome-define": "dist/bin/ome-define.js",
    "ome-plan": "dist/bin/ome-plan.js",
    "ome-build": "dist/bin/ome-build.js",
    "ome-test": "dist/bin/ome-test.js",
    "ome-review": "dist/bin/ome-review.js",
    "ome-ship": "dist/bin/ome-ship.js",
    "ome-spec": "dist/bin/ome-spec.js",
    "ome-mcp": "dist/bin/ome-mcp.js",
    "ome-memory": "dist/bin/ome-memory.js",
    "ome-evolve": "dist/bin/ome-evolve.js",
    "ome-superpowers": "dist/bin/ome-superpowers.js"
  },
  "files": [
    "bin/",
    "dist/index.js",
    "dist/index.d.ts",
    "dist/adapters/",
    "dist/bin/",
    "dist/cli/",
    "dist/core/",
    "dist/scripts/",
    "dist/skills/",
    "schemas/",
    "skills/",
    "docs/framework-api.md",
    "docs/installation-and-usage.md",
    "docs/evolution.md",
    "docs/skill-anatomy.md",
    "docs/lifecycle-workflows.md",
    "docs/skill-quality-gate.md",
    "docs/generated-artifacts.md",
    ".ome/rules/",
    ".ome/platforms.json",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json && node dist/scripts/restore-shebangs.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "verify": "npm run check && npm test",
    "prepack": "npm run verify",
    "test:built": "node --test dist/tests/*.test.js"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1"
  }
}
