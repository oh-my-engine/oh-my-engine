{
  "name": "oh-my-engine",
  "version": "0.3.0",
  "description": "Cross-agent workflow engine for rules, memory, specs, and skills.",
  "type": "commonjs",
  "bin": {
    "ome": "dist/bin/ome.js",
    "ome-init": "dist/bin/ome-init.js",
    "ome-bug": "dist/bin/ome-bug.js",
    "ome-ui": "dist/bin/ome-ui.js",
    "ome-comp": "dist/bin/ome-comp.js",
    "ome-api": "dist/bin/ome-api.js",
    "ome-spec": "dist/bin/ome-spec.js",
    "ome-memory": "dist/bin/ome-memory.js",
    "ome-evolve": "dist/bin/ome-evolve.js"
  },
  "files": [
    "bin/",
    "dist/adapters/",
    "dist/bin/",
    "dist/cli/",
    "dist/core/",
    "dist/scripts/",
    "dist/skills/",
    "schemas/",
    "skills/",
    "docs/installation-and-usage.md",
    "docs/generated-artifacts.md",
    ".ome/rules/",
    ".ome/platforms.json",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json && node dist/scripts/restore-shebangs.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "verify": "npm run check && npm test",
    "prepack": "npm run verify",
    "test:built": "node --test dist/tests/*.test.js"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1"
  }
}
