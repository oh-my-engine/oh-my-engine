{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Oh My Engine Spec State",
  "type": "object",
  "required": ["changeId", "changeSlug", "capability", "mode", "status", "phase", "updatedAt"],
  "properties": {
    "changeId": { "type": "string" },
    "changeSlug": { "type": "string" },
    "capability": { "type": "string" },
    "mode": { "type": "string", "enum": ["feature", "design-first", "bugfix", "import"] },
    "status": { "type": "string", "enum": ["imported", "decomposed", "proposed", "planned", "in_progress", "verify_failed", "verified", "archived"] },
    "phase": { "type": "string", "enum": ["import", "decompose", "propose", "plan", "apply", "verify", "archive"] },
    "updatedAt": { "type": "string" },
    "openTasks": { "type": "number" },
    "completedTasks": { "type": "number" },
    "openAcceptanceCriteria": { "type": "number" },
    "archivedPath": { "type": "string" }
  }
}
